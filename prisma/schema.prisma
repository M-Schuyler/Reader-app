generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DocumentType {
  RSS_ITEM
  WEB_PAGE
  PDF
}

enum ReadState {
  UNREAD
  READING
  READ
}

enum IngestionStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum AiSummaryStatus {
  PENDING
  READY
  FAILED
}

enum TranscriptSource {
  NATIVE
  GEMINI
  NONE
}

enum TranscriptStatus {
  PENDING
  READY
  FAILED
}

enum PublishedAtKind {
  EXACT
  BEFORE
  UNKNOWN
}

enum SourceAliasKind {
  FEED
  DOMAIN
}

enum SourceKind {
  RSS
  WECHAT_ARCHIVE
}

enum SourceSyncMode {
  SCHEDULED
  MANUAL_ONLY
}

enum IngestionJobKind {
  FETCH_WEB_PAGE
  IMPORT_FEED_ITEM
  EXTRACT_PDF_TEXT
  SYNC_FEED
  GENERATE_AI_SUMMARY
  GENERATE_TRANSCRIPT
}

enum IngestionJobStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
}

model Feed {
  id           String         @id @default(cuid())
  title        String
  feedUrl      String
  siteUrl      String?
  isActive     Boolean        @default(true)
  lastSyncedAt DateTime?
  sourceId     String?        @unique
  source       Source?        @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  documents    Document[]
  jobs         IngestionJob[]

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([feedUrl])
  @@index([isActive])
  @@index([lastSyncedAt])
}

model Source {
  id             String             @id @default(cuid())
  kind           SourceKind
  title          String
  slug           String             @unique
  siteUrl        String?
  locatorUrl     String
  includeCategories String[]        @default([])
  isActive       Boolean            @default(true)
  syncMode       SourceSyncMode     @default(SCHEDULED)
  backfillStartAt DateTime?
  lastSyncedAt   DateTime?
  lastSyncStatus IngestionJobStatus?
  lastSyncError  String?

  feed           Feed?
  documents      Document[]
  jobs           IngestionJob[]

  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([kind, createdAt])
  @@index([isActive, syncMode])
  @@index([lastSyncedAt])
  @@index([locatorUrl])
}

model SourceAlias {
  id        String          @id @default(cuid())
  kind      SourceAliasKind
  value     String
  name      String

  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([kind, value])
  @@index([kind, name])
}

model WechatSubsource {
  biz           String   @id
  displayName   String
  isPlaceholder Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Document {
  id              String           @id @default(cuid())
  type            DocumentType
  title           String
  sourceUrl       String?
  canonicalUrl    String?
  videoUrl        String?
  videoProvider   String?
  videoThumbnailUrl String?
  videoDurationSeconds Int?
  transcriptSegments Json?
  transcriptSource  TranscriptSource?
  transcriptStatus  TranscriptStatus?
  // Stable unique key for deduplication across different source URLs and formats.
  dedupeKey       String?          @unique
  // RSS dedupe uses externalId first, then service-level fallback by URL and content hash.
  externalId      String?
  aiSummary       String?
  aiSummaryStatus AiSummaryStatus?
  aiSummaryError  String?
  lang            String?
  excerpt         String?
  author          String?
  contentOriginKey String?
  contentOriginLabel String?
  publishedAt     DateTime?
  publishedAtKind PublishedAtKind  @default(UNKNOWN)
  enteredReadingAt DateTime?
  readState       ReadState        @default(UNREAD)
  isFavorite      Boolean          @default(false)
  readingProgress Float            @default(0)
  ingestionStatus IngestionStatus  @default(PENDING)

  feedId          String?
  feed            Feed?            @relation(fields: [feedId], references: [id], onDelete: SetNull)
  sourceId        String?
  source          Source?          @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  content         DocumentContent?
  file            DocumentFile?
  tags            DocumentTag[]
  highlights      Highlight[]
  jobs            IngestionJob[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([feedId, externalId])
  @@index([type, createdAt])
  @@index([readState, createdAt])
  @@index([isFavorite, createdAt])
  @@index([enteredReadingAt])
  @@index([feedId, publishedAt])
  @@index([publishedAtKind, publishedAt])
  @@index([canonicalUrl])
  @@index([sourceUrl])
  @@index([videoUrl])
  @@index([videoProvider])
  @@index([contentOriginKey])
  @@index([type, externalId])
  @@index([sourceId, publishedAt])
}

model DocumentContent {
  id          String    @id @default(cuid())
  documentId  String    @unique
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  contentHtml String?
  plainText   String
  rawHtml     String?
  textHash    String?
  wordCount   Int?
  extractedAt DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([textHash])
  @@index([extractedAt])
}

model DocumentFile {
  id         String    @id @default(cuid())
  documentId String    @unique
  document   Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  fileName   String
  mimeType   String
  storageKey String
  sizeBytes  Int
  checksum   String
  pageCount  Int?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([checksum])
  @@index([mimeType])
}

model Tag {
  id        String       @id @default(cuid())
  name      String
  slug      String
  documents DocumentTag[]

  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([slug])
  @@unique([name])
}

model DocumentTag {
  documentId String
  tagId      String

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@id([documentId, tagId])
  @@index([tagId, documentId])
}

model Highlight {
  id           String    @id @default(cuid())
  documentId   String
  document     Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  externalId   String?
  quoteText    String
  note         String?
  color        String?
  startOffset  Int?
  endOffset    Int?
  selectorJson Json?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([documentId, externalId])
  @@index([documentId, createdAt])
}

model AiSummaryRunnerState {
  provider                  String   @id
  cooldownUntil             DateTime?
  lastCooldownMs            Int      @default(0)
  consecutiveRateLimitCount Int      @default(0)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model IngestionJob {
  id           String             @id @default(cuid())
  kind         IngestionJobKind
  status       IngestionJobStatus @default(PENDING)

  documentId   String?
  document     Document?          @relation(fields: [documentId], references: [id], onDelete: SetNull)

  feedId       String?
  feed         Feed?              @relation(fields: [feedId], references: [id], onDelete: SetNull)
  sourceId     String?
  source       Source?            @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  sourceUrl    String?
  payloadJson  Json?
  errorMessage String?
  startedAt    DateTime?
  finishedAt   DateTime?

  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([kind, status, createdAt])
  @@index([documentId, createdAt])
  @@index([feedId, createdAt])
  @@index([sourceId, createdAt])
}
