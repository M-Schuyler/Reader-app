{
  "name": "reader-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev/guard-worktree-command.mjs dev",
    "dev:local": "node scripts/dev/run-worktree-command.mjs dev",
    "build": "node scripts/dev/guard-worktree-command.mjs build",
    "build:local": "node scripts/dev/run-worktree-command.mjs build",
    "start": "node .next/standalone/server.js",
    "test:extractor": "node --import tsx --test tests/**/*.test.ts",
    "smoke:wechat": "node --import tsx scripts/smoke/wechat-capture.ts",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "cheerio": "^1.2.0",
    "next": "^15.0.0",
    "next-auth": "5.0.0-beta.30",
    "node-html-markdown": "^2.0.0",
    "openai": "^6.32.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "playwright": "^1.58.2",
    "postcss": "^8.0.0",
    "prisma": "^6.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
