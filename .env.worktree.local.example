# Optional worktree-only overrides for local development.
# These values win over `.env`, but this file stays out of git.
#
# Typical use:
# - point a worktree at local Postgres while the main repo keeps a remote `.env.local`
# - set a throwaway AUTH_SECRET for local QA
#
# Example:
# DATABASE_URL="postgresql://chenshukai@localhost:5432/reader_app?schema=public"
# AUTH_SECRET="qa-dev-secret"
